FROM node:20-alpine AS builder

WORKDIR /app

COPY packages/shell/package*.json ./
RUN npm install

COPY packages/shell .

# Sostituisce l'URL API con quello di produzione
ARG API_URL=https://lifeos-platform-api.fly.dev
RUN sed -i "s|http://localhost:3000|${API_URL}|g" proxy.conf.json 2>/dev/null || true

RUN npx ng build --configuration=production

FROM nginx:alpine
COPY --from=builder /app/dist/shell/browser /usr/share/nginx/html
COPY infra/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
